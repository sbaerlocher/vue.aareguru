{
  "name": "vue.aareguru",
  "version": "2.3.1",
  "type": "module",
  "description": "Vue 3 component that displays the Aare river temperature from Aareguru API.",
  "main": "dist/vue.aareguru.cjs",
  "module": "dist/vue.aareguru.mjs",
  "unpkg": "dist/vue.aareguru.js",
  "jsdelivr": "dist/vue.aareguru.js",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && pnpm build:types",
    "build:bundle": "pnpm build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "format": "prettier --write '**/*.{vue,ts,js,cjs,mjs,json,md,css,yml,yaml}'",
    "format:check": "prettier --check '**/*.{vue,ts,js,cjs,mjs,json,md,css,yml,yaml}'",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --project unit --coverage",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:watch": "vue-tsc --noEmit --watch",
    "validate": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test",
    "clean": "rm -rf dist coverage node_modules/.vite",
    "clean:all": "pnpm clean && rm -rf node_modules pnpm-lock.yaml",
    "prepare": "test ! -e .git || ! command -v git >/dev/null 2>&1 || lefthook install",
    "prepublishOnly": "pnpm typecheck && pnpm test:coverage",
    "storybook": "pnpm dev",
    "build:storybook": "storybook build"
  },
  "files": [
    "dist",
    "src/components/AareGuru.vue",
    "src/types/index.d.ts"
  ],
  "types": "dist/types/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/vue.aareguru.mjs",
      "require": "./dist/vue.aareguru.cjs"
    },
    "./types": {
      "types": "./src/types/index.d.ts"
    },
    "./style.css": "./dist/vue.aareguru.css",
    "./package.json": "./package.json"
  },
  "keywords": [
    "vue",
    "vue3",
    "component",
    "aare",
    "aareguru",
    "temperature",
    "switzerland",
    "bern",
    "river"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbaerlocher/vue.aareguru.git"
  },
  "bugs": {
    "url": "https://github.com/sbaerlocher/vue.aareguru/issues"
  },
  "homepage": "https://github.com/sbaerlocher/vue.aareguru#readme",
  "peerDependencies": {
    "axios": "^1.18.1",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/vue3-vite": "10.4.6",
    "@types/node": "25.9.4",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "@vue/compiler-sfc": "3.5.38",
    "@vue/test-utils": "2.4.11",
    "axios": "1.18.1",
    "eslint": "10.6.0",
    "eslint-plugin-storybook": "10.4.6",
    "eslint-plugin-vue": "10.9.2",
    "happy-dom": "20.10.6",
    "lefthook": "2.1.9",
    "msw": "2.14.6",
    "msw-storybook-addon": "2.0.7",
    "playwright": "1.61.1",
    "prettier": "3.9.1",
    "storybook": "10.4.6",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "vue": "3.5.38",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "overrides": {
    "glob": "^13.0.6",
    "flatted": "^3.4.2",
    "minimatch": "^10.2.5",
    "rollup": "^4.62.2"
  }
}
